 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 📊 Notebook 5 — Model Evaluation & Comparison\n",
    "## Aerial Bird vs Drone Classification\n",
    "\n",
    "**Objectives:**\n",
    "- Load all trained models\n",
    "- Evaluate each on test set\n",
    "- Confusion matrix, ROC, classification report\n",
    "- Cross-model comparison table\n",
    "- Select & save best model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, sys, json\n",
    "import numpy as np\n",
    "import tensorflow as tf\n",
    "from pathlib import Path\n",
    "\n",
    "ROOT = Path(os.getcwd()).parent\n",
    "sys.path.insert(0, str(ROOT))\n",
    "\n",
    "from src.config import (\n",
    "    CUSTOM_CNN_PATH, RESNET50_PATH, MOBILENET_PATH,\n",
    "    EFFICIENTNET_PATH, BEST_MODEL_PATH, PLOTS_DIR, REPORTS_DIR\n",
    ")\n",
    "from src.data_preprocessing import get_test_generator\n",
    "from src.evaluate import evaluate_model, compare_models, select_best_model\n",
    "from src.utils import ensure_dirs, set_seed\n",
    "\n",
    "set_seed()\n",
    "ensure_dirs(PLOTS_DIR, REPORTS_DIR)\n",
    "test_gen = get_test_generator()\n",
    "print('✅ Ready for evaluation')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load All Trained Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model_paths = {\n",
    "    'Custom CNN':    CUSTOM_CNN_PATH,\n",
    "    'ResNet50':      RESNET50_PATH,\n",
    "    'MobileNetV2':   MOBILENET_PATH,\n",
    "    'EfficientNetB0': EFFICIENTNET_PATH,\n",
    "}\n",
    "\n",
    "model_objects = {}\n",
    "for name, path in model_paths.items():\n",
    "    if os.path.exists(path):\n",
    "        model_objects[name] = tf.keras.models.load_model(path)\n",
    "        print(f'✅ Loaded: {name}')\n",
    "    else:\n",
    "        print(f'⚠️  Not found: {name} ({path})')\n",
    "\n",
    "print(f'\\nLoaded {len(model_objects)} models')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Evaluate Each Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "all_results = {}\n",
    "for name, model in model_objects.items():\n",
    "    print(f'\\n{'='*50}')\n",
    "    print(f'  Evaluating: {name}')\n",
    "    print(f'{'='*50}')\n",
    "    test_gen.reset()\n",
    "    results = evaluate_model(model, test_gen, model_name=name)\n",
    "    all_results[name] = results\n",
    "\n",
    "print(f'\\n✅ Evaluated {len(all_results)} models')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Model Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if len(all_results) > 1:\n",
    "    df = compare_models(all_results)\n",
    "    display(df)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Select Best Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if all_results and model_objects:\n",
    "    best_name, best_model = select_best_model(\n",
    "        all_results, model_objects,\n",
    "        save_path=BEST_MODEL_PATH,\n",
    "        metric='f1'\n",
    "    )\n",
    "    print(f'\\n🏆 Best model: {best_name}')\n",
    "    print(f'   Saved to: {BEST_MODEL_PATH}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Final Summary Report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "summary_path = os.path.join(REPORTS_DIR, 'final_summary.json')\n",
    "if os.path.exists(summary_path):\n",
    "    with open(summary_path) as f:\n",
    "        summary = json.load(f)\n",
    "    print(json.dumps(summary, indent=2))\n",
    "\n",
    "print('\\n✅ Evaluation complete!')\n",
    "print(f'  Plots saved in: {PLOTS_DIR}')\n",
    "print(f'  Reports saved in: {REPORTS_DIR}')"
   ]
  }
 ],
